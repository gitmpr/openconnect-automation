# VPN environment configuration
# All site-specific and personal settings live here.
# The scripts read only from this file.
#
# If this file contains a plain-text password, restrict permissions:
#   chmod 600 config/vpn.conf

[vpn]
# Full URL to the VPN portal (including any path component required by the server)
server = https://vpnportal.example.com/mfa
# Your VPN login username (without the domain suffix)
username = jdoe
# Path to the openconnect binary
openconnect_path = /usr/sbin/openconnect
# Protocol: nc (Juniper NetConnect) or pulse (Pulse Secure)
protocol = nc

[credentials]
# Active Directory username, including domain suffix
ad_username = jdoe@example.local

# --- AD password: choose exactly one method ---

# Option A: plain text password (simpler; ensure file permissions are 600)
# ad_password = your_password_here

# Option B: shell command that prints the password to stdout (recommended)
# The entire value after '=' is passed verbatim to /bin/sh -c, so spaces,
# subshells $(...), and pipes work as normal. No quoting of the config value
# itself is needed or supported -- quoting only applies within the command
# where an argument contains spaces (e.g. bw get password "My Item").
# See bash_commands/get_ad_password.sh for examples with other backends.
ad_password_cmd = secret-tool lookup service ad username jdoe@example.local

# --- TOTP: choose exactly one method ---

# Option A: raw base32 TOTP secret; the script calls oathtool to generate the code
# totp_secret = YOUR_BASE32_SECRET

# Option B: shell command that prints the current TOTP code (6-8 digits) to stdout
# See bash_commands/get_totp_code.sh for examples with other backends.
totp_code_cmd = oathtool --totp --base32 $(secret-tool lookup totp totp_vpn)

[dns_servers]
# Corporate DNS servers assigned to the VPN tunnel interface
primary = 10.0.0.1
secondary = 10.0.0.2

[search_domains]
# Comma-separated list of corporate DNS search domains
domains = example.local,corp.example.com

[routing_domains]
# Domains forwarded to the VPN DNS via systemd-resolved routing rules (~domain syntax)
# Usually identical to search_domains
domains = example.local,corp.example.com
